<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox spacing="10" style="-fx-padding:15;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="co.edu.uniquindio.poo.inmobiliariaproyecto.viewController.TransaccionesViewController">
    <Label text="Gestión de Transacciones" style="-fx-font-size:15;-fx-font-weight:bold;"/>
    <HBox spacing="15">
        <VBox spacing="6" style="-fx-border-color:#aaa;-fx-padding:10;" prefWidth="300">
            <Label text="Registrar Transacción" style="-fx-font-weight:bold;"/>
            <Label text="Comprador:"/><ComboBox fx:id="cmbComprador" prefWidth="200"/>
            <Label text="Inmueble:"/><ComboBox fx:id="cmbInmueble" prefWidth="200"/>
            <Label text="Valor Final:"/><TextField fx:id="txtValorFinal" promptText="Valor final"/>
            <Label text="Tipo Operación:"/><ComboBox fx:id="cmbTipoOperacion" prefWidth="200"/>
            <HBox spacing="6">
                <Button text="Registrar" onAction="#registrarTransaccion" prefWidth="90"/>
                <Button text="Eliminar" onAction="#eliminarTransaccion" prefWidth="90"/>
            </HBox>
            <Separator/>
            <Label text="Actualizar Valor" style="-fx-font-weight:bold;"/>
            <Label text="Código TX:"/><TextField fx:id="txtCodigoActualizar" promptText="Código TX"/>
            <Label text="Nuevo valor:"/><TextField fx:id="txtNuevoValor" promptText="Nuevo valor"/>
            <Button text="Actualizar" onAction="#actualizarTransaccion" prefWidth="200"/>
            <Label fx:id="lblMensaje" wrapText="true"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Historial de Transacciones" style="-fx-font-weight:bold;"/>
            <TableView fx:id="tablaTransacciones" prefHeight="430" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
                    <TableColumn fx:id="colComprador" text="Comprador" prefWidth="110"/>
                    <TableColumn fx:id="colVendedor" text="Vendedor" prefWidth="110"/>
                    <TableColumn fx:id="colInmueble" text="Inmueble" prefWidth="90"/>
                    <TableColumn fx:id="colValor" text="Valor" prefWidth="100"/>
                    <TableColumn fx:id="colTipo" text="Tipo Op." prefWidth="80"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>