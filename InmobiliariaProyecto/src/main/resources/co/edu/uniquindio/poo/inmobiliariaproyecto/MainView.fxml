<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.poo.inmobiliariaproyecto.viewController.MainViewController">
    <top>
        <VBox style="-fx-background-color:#2c3e50;-fx-padding:10;">
            <Label text="InmoSmart - Plataforma Inmobiliaria Digital" style="-fx-text-fill:white;-fx-font-size:18;-fx-font-weight:bold;"/>
        </VBox>
    </top>
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <Tab text="Usuarios"><fx:include source="UsuariosView.fxml"/></Tab>
            <Tab text="Inmuebles"><fx:include source="InmueblesView.fxml"/></Tab>
            <Tab text="Ofertas"><fx:include source="OfertasView.fxml"/></Tab>
            <Tab text="Transacciones"><fx:include source="TransaccionesView.fxml"/></Tab>
            <Tab text="Reportes"><fx:include source="ReportesView.fxml"/></Tab>
        </TabPane>
    </center>
</BorderPane>